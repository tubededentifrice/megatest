{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": { "enabled": true },
  "files": {
    "include": ["projects/*/src/**/*.ts", "projects/*/test/**/*.ts"],
    "ignore": ["projects/*/dist", "projects/*/node_modules", "node_modules", "mocks"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "warn" },
      "style": { "noNonNullAssertion": "warn", "useConst": "error", "useTemplate": "off" },
      "complexity": { "noForEach": "off" }
    }
  }
}
